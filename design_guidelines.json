  "code_snippets": {
    "hero_html_css": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700;12..96,800&family=DM+Sans:wght@400;500;600&display=swap');\n  .e1-hero-container {\n    position: relative;\n    width: 100%;\n    min-height: 55vh;\n    border-radius: 24px;\n    overflow: hidden;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding: 4rem;\n    background: linear-gradient(135deg, rgba(10,10,10,0.95), rgba(20,20,20,0.85)), url('https://images.unsplash.com/photo-1560930950-5cc20e80e392?crop=entropy&cs=srgb&fm=jpg') center/cover;\n    font-family: 'DM Sans', sans-serif;\n    color: #FFFFFF;\n    box-shadow: 0 20px 40px rgba(0,0,0,0.4);\n    border: 1px solid rgba(255,255,255,0.05);\n    margin-bottom: 2rem;\n  }\n  .e1-hero-badge {\n    display: inline-block;\n    background: rgba(255, 31, 83, 0.15);\n    border: 1px solid rgba(255, 31, 83, 0.4);\n    color: #FF1F53;\n    padding: 0.5rem 1rem;\n    border-radius: 999px;\n    font-weight: 600;\n    font-size: 0.875rem;\n    margin-bottom: 1.5rem;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    width: fit-content;\n  }\n  .e1-hero-title {\n    font-family: 'Bricolage Grotesque', sans-serif;\n    font-size: clamp(2.5rem, 5vw, 4.5rem);\n    font-weight: 800;\n    line-height: 1.05;\n    margin: 0 0 1.5rem 0;\n    letter-spacing: -0.03em;\n  }\n  .e1-hero-title span {\n    color: #FF1F53;\n  }\n  .e1-hero-subtitle {\n    font-size: 1.125rem;\n    color: #D4D4D8;\n    max-width: 600px;\n    line-height: 1.6;\n    margin: 0 0 2.5rem 0;\n  }\n  .e1-hero-author {\n    font-size: 0.875rem;\n    color: #A1A1AA;\n    border-top: 1px solid rgba(255,255,255,0.1);\n    padding-top: 1.5rem;\n    margin-top: auto;\n  }\n  .e1-hero-author strong {\n    color: #FFFFFF;\n  }\n  .e1-tech-stack {\n    display: flex;\n    gap: 0.75rem;\n    margin-bottom: 2rem;\n    flex-wrap: wrap;\n  }\n  .e1-tech-badge {\n    background: rgba(255,255,255,0.05);\n    border: 1px solid rgba(255,255,255,0.1);\n    padding: 0.25rem 0.75rem;\n    border-radius: 6px;\n    font-size: 0.75rem;\n    color: #E4E4E7;\n  }\n</style>\n<div class=\"e1-hero-container\" data-testid=\"landing-hero\">\n  <div class=\"e1-hero-badge\">Berlin Analytics Engine</div>\n  <h1 class=\"e1-hero-title\">Decoding Berlin's<br><span>Airbnb Landscape.</span></h1>\n  <p class=\"e1-hero-subtitle\">A high-performance pipeline analyzing 17,499 listings and 409K reviews to uncover pricing trends, geographical hotspots, and guest sentiment.</p>\n  <div class=\"e1-tech-stack\">\n    <span class=\"e1-tech-badge\">DuckDB</span>\n    <span class=\"e1-tech-badge\">dbt</span>\n    <span class=\"e1-tech-badge\">Streamlit</span>\n    <span class=\"e1-tech-badge\">Plotly</span>\n    <span class=\"e1-tech-badge\">Python</span>\n  </div>\n  <div class=\"e1-hero-author\">Built by <strong>Zehair Louzza</strong> &bull; MBA ESG Big Data & AI 2026</div>\n</div>",
    "kpi_cards_css": "<style>\n  .e1-kpi-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n    gap: 1.5rem;\n    margin: 2rem 0;\n  }\n  .e1-kpi-card {\n    background: #141414;\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    border-radius: 16px;\n    padding: 1.5rem;\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    position: relative;\n    overflow: hidden;\n  }\n  .e1-kpi-card::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; width: 100%; height: 3px;\n    background: #FF1F53;\n    transform: scaleX(0);\n    transform-origin: left;\n    transition: transform 0.4s ease;\n  }\n  .e1-kpi-card:hover {\n    transform: translateY(-4px);\n    border-color: rgba(255, 31, 83, 0.3);\n    box-shadow: 0 12px 24px rgba(0,0,0,0.4);\n  }\n  .e1-kpi-card:hover::before {\n    transform: scaleX(1);\n  }\n  .e1-kpi-label {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.875rem;\n    color: #A1A1AA;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    font-weight: 600;\n    margin-bottom: 0.5rem;\n  }\n  .e1-kpi-value {\n    font-family: 'Bricolage Grotesque', sans-serif;\n    font-size: 2.5rem;\n    font-weight: 800;\n    color: #FFFFFF;\n    line-height: 1;\n  }\n  .e1-kpi-subtext {\n    font-size: 0.75rem;\n    color: #71717A;\n    margin-top: 0.5rem;\n  }\n</style>\n<div class=\"e1-kpi-grid\" data-testid=\"kpi-grid\">\n  <div class=\"e1-kpi-card\">\n    <div class=\"e1-kpi-label\">Logements Actifs</div>\n    <div class=\"e1-kpi-value\">17,499</div>\n    <div class=\"e1-kpi-subtext\">Sur tout Berlin</div>\n  </div>\n  <div class=\"e1-kpi-card\">\n    <div class=\"e1-kpi-label\">Prix Moyen</div>\n    <div class=\"e1-kpi-value\">75€</div>\n    <div class=\"e1-kpi-subtext\">Par nuitée</div>\n  </div>\n  <div class=\"e1-kpi-card\">\n    <div class=\"e1-kpi-label\">Note Moyenne</div>\n    <div class=\"e1-kpi-value\">4.14<span style=\"font-size:1.5rem;color:#FFD700\">/5</span></div>\n    <div class=\"e1-kpi-subtext\">Satisfaction globale</div>\n  </div>\n  <div class=\"e1-kpi-card\">\n    <div class=\"e1-kpi-label\">Avis Analysés</div>\n    <div class=\"e1-kpi-value\">409K</div>\n    <div class=\"e1-kpi-subtext\">Analyse de sentiment incluse</div>\n  </div>\n</div>",
    "pipeline_diagram_css": "<style>\n  .e1-pipeline-wrapper {\n    background: #0A0A0A;\n    padding: 2.5rem;\n    border-radius: 20px;\n    border: 1px solid rgba(255,255,255,0.05);\n    margin: 2rem 0;\n  }\n  .e1-pipeline-header {\n    font-family: 'Bricolage Grotesque', sans-serif;\n    color: #FFF;\n    font-size: 1.5rem;\n    margin-bottom: 2rem;\n    text-align: center;\n  }\n  .e1-pipeline-container {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 1rem;\n    overflow-x: auto;\n    padding-bottom: 1rem;\n  }\n  .e1-pipeline-node {\n    background: #141414;\n    border: 1px solid rgba(255,255,255,0.1);\n    border-radius: 12px;\n    padding: 1.5rem;\n    min-width: 180px;\n    text-align: center;\n    position: relative;\n    z-index: 2;\n    transition: transform 0.3s ease;\n  }\n  .e1-pipeline-node:hover {\n    transform: translateY(-4px);\n  }\n  .e1-pipeline-node[data-tier=\"bronze\"] { border-top: 4px solid #CD7F32; }\n  .e1-pipeline-node[data-tier=\"silver\"] { border-top: 4px solid #C0C0C0; }\n  .e1-pipeline-node[data-tier=\"gold\"] { border-top: 4px solid #FFD700; }\n  .e1-pipeline-title {\n    font-family: 'Bricolage Grotesque', sans-serif;\n    font-size: 1.25rem;\n    font-weight: 700;\n    color: #FFF;\n    margin-bottom: 0.5rem;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n  .e1-pipeline-desc {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.875rem;\n    color: #A1A1AA;\n    line-height: 1.4;\n  }\n  .e1-pipeline-arrow {\n    height: 2px;\n    flex-grow: 1;\n    background: linear-gradient(90deg, rgba(255,255,255,0.1) 0%, rgba(255,31,83,0.5) 50%, rgba(255,255,255,0.1) 100%);\n    position: relative;\n    min-width: 50px;\n  }\n  .e1-pipeline-arrow::after {\n    content: '';\n    position: absolute;\n    right: 0;\n    top: 50%;\n    transform: translateY(-50%) rotate(-45deg);\n    border: solid #FF1F53;\n    border-width: 0 2px 2px 0;\n    display: inline-block;\n    padding: 5px;\n  }\n</style>\n<div class=\"e1-pipeline-wrapper\" data-testid=\"pipeline-diagram\">\n  <div class=\"e1-pipeline-header\">Data Architecture</div>\n  <div class=\"e1-pipeline-container\">\n    <div class=\"e1-pipeline-node\" data-tier=\"bronze\">\n      <div class=\"e1-pipeline-title\" style=\"color: #CD7F32\">Bronze</div>\n      <div class=\"e1-pipeline-desc\">Données brutes<br>(DuckDB)</div>\n    </div>\n    <div class=\"e1-pipeline-arrow\"></div>\n    <div class=\"e1-pipeline-node\" data-tier=\"silver\">\n      <div class=\"e1-pipeline-title\" style=\"color: #C0C0C0\">Silver</div>\n      <div class=\"e1-pipeline-desc\">Nettoyage & Filtres<br>(dbt)</div>\n    </div>\n    <div class=\"e1-pipeline-arrow\"></div>\n    <div class=\"e1-pipeline-node\" data-tier=\"gold\">\n      <div class=\"e1-pipeline-title\" style=\"color: #FFD700\">Gold</div>\n      <div class=\"e1-pipeline-desc\">Agrégations KPI<br>(Streamlit)</div>\n    </div>\n  </div>\n</div>"
  },
  "instructions_to_main_agent": "Inject the provided HTML/CSS blocks using `st.markdown(snippet, unsafe_allow_html=True)` inside the 'Accueil' tab of the Streamlit application. Make sure the dark theme configuration is forced via Streamlit's config.toml or `st.set_page_config` if necessary, to match this dark urban aesthetic. Use Streamlit buttons or `st.page_link` for the CTAs below the Hero section to navigate to other tabs."
}