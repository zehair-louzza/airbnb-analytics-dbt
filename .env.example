# Airbnb Analytics - Variables d environnement
# Copiez ce fichier en .env et remplissez les valeurs
# cp .env.example .env

# Chemin vers la base DuckDB
DUCKDB_PATH=./data/airbnb.duckdb

# Chemin vers les fichiers CSV sources
DATA_RAW_DIR=./data/raw

# Profil dbt (dev ou prod)
DBT_PROFILE=airbnb_duckdb
DBT_TARGET=dev

# Streamlit (optionnel)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
